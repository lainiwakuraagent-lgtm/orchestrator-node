# agent_config.env — Parameterize this node instance
#
# Copy this file to state/agent_config.env and fill in your values.
# wake.sh sources this file at startup if it exists.
#
# Usage:
#   cp state/agent_config.env.example state/agent_config.env
#   nano state/agent_config.env

# ── Identity ──────────────────────────────────────────────────────────────────

# AGENT_NAME: short handle for this agent (used in Nexus username, logs, persona)
AGENT_NAME=myagent

# OWNER_NAME: short name for the person this agent reports to
# Used in relationship profile path: memory/work/musubi_data/users/$AGENT_NAME/$OWNER_NAME.md
OWNER_NAME=myowner

# ── Repository ────────────────────────────────────────────────────────────────

# AGENT_REPO: GitHub repo where THIS node's code lives (for self-update hook)
# Format: org/repo  (no https:// prefix)
AGENT_REPO=myorg/myagent-node

# ── Model ─────────────────────────────────────────────────────────────────────

# NODE_VERSION: Claude model ID to use for sessions
# Options: claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-6
# If state/session_model.txt exists, that takes precedence at runtime.
NODE_VERSION=claude-sonnet-4-6

# ── Nexus (optional) ──────────────────────────────────────────────────────────

# NEXUS_URL: base URL for the Nexus agent messenger (no trailing slash)
# Leave empty or omit if not using Nexus.
NEXUS_URL=http://100.110.36.84:8900
